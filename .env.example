NEXT_PUBLIC_CLIENT_BUSINESS_NAME="PeakForm Coaching"
NEXT_PUBLIC_CLIENT_PHONE="(555) 014-2048"
NEXT_PUBLIC_CLIENT_EMAIL="hello@peakform.test"
NEXT_PUBLIC_CLIENT_ADDRESS="418 Summit Ave, Austin, TX"

# Production site URL used for canonical links, sitemap, robots, and share metadata.
# Set this to the real Vercel/custom domain, for example "https://www.clientdomain.com".
NEXT_PUBLIC_SITE_URL="https://www.peakformcoaching.com"
NEXT_PUBLIC_BOOKING_URL=""

# Starter admin route protection for demos.
# TODO: Replace with Supabase Auth, Clerk, or another proper auth provider for larger clients.
ADMIN_PASSWORD=""

# Optional server-only secret for signing admin session cookies.
# If omitted, ADMIN_PASSWORD is used as the signing secret.
# Recommended on Vercel: set a separate long random value for production.
ADMIN_SESSION_SECRET=""

# Supabase server-side lead storage.
# TODO: Create a Supabase project for each client and set these on the server.
SUPABASE_URL=""

# Server-only secret. Never prefix this with NEXT_PUBLIC_ and never expose it in frontend code.
SUPABASE_SERVICE_ROLE_KEY=""

# Optional public key for future client-side Supabase reads with RLS policies.
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# Resend email notifications for new leads.
# TODO: Verify a sending domain in Resend for each client before production.
RESEND_API_KEY=""
LEAD_NOTIFICATION_FROM_EMAIL="PeakForm Coaching <leads@example.com>"
LEAD_NOTIFICATION_TO_EMAIL="owner@example.com"

# Optional confirmation email sent to the lead after Supabase saves the inquiry.
LEAD_CONFIRMATION_EMAIL_ENABLED="false"

# Optional for a future live AI integration.
# Server-only OpenAI key for the Review Response Generator. Never prefix this with NEXT_PUBLIC_.
OPENAI_API_KEY=""

# Optional model overrides. Default to a cost-conscious model in the server routes.
OPENAI_REVIEW_MODEL="gpt-5.4-mini"
OPENAI_FOLLOW_UP_MODEL="gpt-5.4-mini"
