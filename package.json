{
  "name": "clientflow-ai-template",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node --require ./scripts/normalize-readlink.cjs ./node_modules/next/dist/bin/next dev",
    "build": "node --require ./scripts/normalize-readlink.cjs ./node_modules/next/dist/bin/next build",
    "start": "node --require ./scripts/normalize-readlink.cjs ./node_modules/next/dist/bin/next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "next": "^15.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@types/node": "^22.15.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.25.0",
    "eslint-config-next": "^15.3.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3"
  }
}
